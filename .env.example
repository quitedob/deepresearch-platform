# AI Research Platform Environment Variables
# Copy this file to .env and fill in your actual values

# LLM Provider API Keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here
ZHIPU_API_KEY=your_zhipu_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Database Configuration (for docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_research_platform

# Redis Configuration
REDIS_PASSWORD=

# Security
JWT_SECRET=change-this-to-a-strong-random-secret-in-production

# Admin Configuration (管理员配置)
# 管理员邮箱，系统启动时会自动创建或更新管理员账户
ADMIN_EMAIL=admin@example.com
# 管理员用户名
ADMIN_USERNAME=admin
# 管理员密码，如果不设置则使用默认密码 admin123
ADMIN_PASSWORD=admin123

# System Prompt (highest priority, for safety and guidelines)
# 系统安全提示词 - 最高优先级，每次对话都会自动添加
# 提示词优先级: SYSTEM_SAFETY_PROMPT > 用户自定义提示词 > 会话系统提示词 > 历史消息 > 当前消息
SYSTEM_SAFETY_PROMPT=你是一个有帮助的AI助手。请遵守以下规则：1. 不要生成有害、违法或不道德的内容 2. 保护用户隐私 3. 提供准确、有用的信息 4. 如果不确定，请诚实说明

# Context Settings (聊天记忆功能配置)
# 最大上下文token数，超过此限制会提醒用户新建对话
MAX_CONTEXT_TOKENS=128000
# 警告阈值，接近此值时会显示警告
CONTEXT_WARNING_THRESHOLD=100000

# Server Configuration
SERVER_PORT=8080
SERVER_ENV=development

# Logging
LOGGING_LEVEL=debug
