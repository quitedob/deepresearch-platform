# 推荐 .gitignore 内容 — 包含你要忽略的目录和常用模式

# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib
bin/
dist/

# Test binary, built with `go test`
*.test

# Output of the go coverage tool
*.out
coverage.html
docs/
# Dependency directories
vendor/

# Go workspace file
go.work

# Environment variables
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/
.cursor/
*.swp
*.swo
*~
.claude/

# OS
.DS_Store
Thumbs.db

# Claude AI / Kiro
.claude/
.kiro/

# Logs
*.log
logs/

# Temporary files
tmp/
temp/

# Config overrides
config.local.yaml
config.*.yaml
!config.yaml

# Additional common patterns
*.tar.gz
*.zip
*.rar
*.7z

# Database
*.db
*.sqlite
*.sqlite3

# Node.js (frontend)
vue/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Docker
.dockerignore

# Air live reload
tmp/
